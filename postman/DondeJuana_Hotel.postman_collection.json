{
  "info": {
    "name": "DondeJuana Hotel API",
    "_postman_id": "dondejuana-hotel-2026-endpoints",
    "description": "Colección completa de pruebas de endpoints para el backend del Hotel Donde Juana.\n\nAutenticación: HTTP Basic Auth (usuario admin / admin123)\nURL base: http://localhost:8080\n\nMódulos cubiertos:\n- Auth (login form)\n- Tipos de Habitación (/api/tipos-habitacion)\n- Habitaciones (/api/habitaciones)\n- Huéspedes / Personas (/api/personas)\n- Reservas (/api/reservas)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "basic",
    "basic": [
      { "key": "username", "value": "{{username}}", "type": "string" },
      { "key": "password", "value": "{{password}}", "type": "string" }
    ]
  },
  "item": [
    {
      "name": "00. Auth",
      "item": [
        {
          "name": "Login exitoso (form)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "username", "value": "{{username}}", "type": "text" },
                { "key": "password", "value": "{{password}}", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/login",
              "host": ["{{baseUrl}}"],
              "path": ["login"]
            },
            "description": "POST /login con credenciales válidas. Espera redirect (302) o 200. Postman guarda automáticamente la cookie JSESSIONID."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login retorna 200 o 302', function () {",
                  "  pm.expect([200, 302]).to.include(pm.response.code);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login fallido (credenciales incorrectas)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "username", "value": "admin", "type": "text" },
                { "key": "password", "value": "wrong_password", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/login",
              "host": ["{{baseUrl}}"],
              "path": ["login"]
            },
            "description": "POST /login con contraseña incorrecta. Espera redirect a /login?error=true."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login fallido redirige a login?error', function () {",
                  "  pm.expect([200, 302]).to.include(pm.response.code);",
                  "  if (pm.response.code === 302) {",
                  "    pm.expect(pm.response.headers.get('Location')).to.include('error');",
                  "  }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Basic Auth - Acceso sin credenciales (401)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/personas",
              "host": ["{{baseUrl}}"],
              "path": ["api", "personas"]
            },
            "description": "GET /api/personas sin autenticación. Espera 401 Unauthorized."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Sin credenciales retorna 401', function () {",
                  "  pm.expect(pm.response.code).to.equal(401);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
